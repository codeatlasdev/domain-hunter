Output web/app/public/docs/pricing.gif

Set Shell "zsh"
Set FontSize 15
Set Width 800
Set Height 400
Set Theme "Catppuccin Mocha"
Set Padding 16
Set Framerate 24
Set TypingSpeed 35ms
Set CursorBlink false
Type "# Check a brand with pricing"
Enter
Type "domh scan zuvotrix --preset startup --batch --yes"
Enter
Sleep 12s
