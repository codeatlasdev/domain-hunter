Output web/app/public/docs/quick-start.gif

Set Shell "zsh"
Set FontSize 15
Set Width 800
Set Height 400
Set Theme "Catppuccin Mocha"
Set Padding 16
Set Framerate 24
Set TypingSpeed 35ms
Set CursorBlink false
Type "# Install domh"
Enter
Type "go install github.com/codeatlasdev/domain-hunter@latest"
Enter
Sleep 2s

Type ""
Enter
Type "# Run it"
Enter
Type "domh version"
Enter
Sleep 2s
