Output web/app/public/docs/tui.gif

Set Shell "zsh"
Set FontSize 14
Set Width 1100
Set Height 600
Set Theme "Catppuccin Mocha"
Set Padding 16
Set Framerate 30
Set TypingSpeed 35ms
Set CursorBlink false
Type "domh scan --tld com --length 3 --pattern cvc --workers 50"
Enter
Sleep 15s
Type "q"
Sleep 1s
