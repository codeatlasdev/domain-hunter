Output web/app/public/docs/tui.gif

Set Shell "fish"
Set FontSize 13
Set Width 900
Set Height 500
Set Theme "Catppuccin Mocha"
Set Padding 12
Set Framerate 30
Set TypingSpeed 30ms
Set CursorBlink false

Type "domh scan --tld com --length 3 --pattern cvc --workers 50"
Enter
Sleep 15s
Type "q"
Sleep 1s
