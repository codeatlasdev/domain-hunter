Output web/app/public/docs/scan.gif

Set Shell "zsh"
Set FontSize 15
Set Width 800
Set Height 450
Set Theme "Catppuccin Mocha"
Set Padding 16
Set Framerate 24
Set TypingSpeed 35ms
Set CursorBlink false
Type "# Scan 4-letter .com domains"
Enter
Type "domh scan --tld com --length 4 --pattern cvcv --batch --yes"
Enter
Sleep 12s
